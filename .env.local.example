# Copy to .env.local for local (non-Docker) development.
# Docker Compose injects these automatically — no copy needed for the demo.

# PostgreSQL connection. The compose stack uses 'db' as the host.
DATABASE_URL="postgresql://simplyserved:simplyserved@localhost:5432/simplyserved?schema=public"

# Redis used for pub/sub fan-out + future caching/rate-limit.
REDIS_URL="redis://localhost:6379"

# 32+ char secret used to sign session JWTs. REQUIRED in production.
AUTH_SECRET="change-me-to-a-32-plus-char-random-string-please"

# (Optional) HMAC secret for impression hashing. Falls back to AUTH_SECRET.
# IMPRESSION_SECRET=""

# -----------------------------------------------------------------------------
# Scraping / OSINT (all optional — OSM works with no config)
# -----------------------------------------------------------------------------
# Override the Overpass endpoint (e.g. point at a self-hosted instance).
# OVERPASS_URL="https://overpass-api.de/api/interpreter"

# Yelp Fusion API key. When unset the Yelp scraper cleanly no-ops.
# YELP_API_KEY=""

# Google Places API key (Places API New). When unset the Google scraper no-ops.
# GOOGLE_PLACES_API_KEY=""

# Set to "1" to enable the generic chamber-of-commerce HTML adapter (configured
# via data/chambers.json). Off by default.
# SCRAPE_CHAMBERS=""

# Set to "1" to enable Facebook/Instagram OG-metadata enrichment for URLs we
# already discovered. We never scrape private content.
# SCRAPE_SOCIAL_OG=""

# Price-comparison enrichment. Each reads only the public schema.org JSON-LD a
# storefront page already exposes to search engines, to attach price quotes +
# imagery. Targets are storefront URLs. All off by default.
# SCRAPE_WEBSITE_OFFERS=""   # the company's own website (DIRECT channel)
# SCRAPE_DOORDASH=""         # DoorDash store page (DOORDASH channel)
# SCRAPE_ANGI=""             # Angi pro page (ANGI channel)

# -----------------------------------------------------------------------------
# Real-time onboarding agent websocket transport
# -----------------------------------------------------------------------------
# Public URL used by the onboarding client component (browser-visible).
# Example for local: ws://localhost:3001/api/agent/onboarding/ws
# ONBOARDING_WS_URL=""

# Socket server bind settings (used by `npm run ws:onboarding`).
# ONBOARDING_WS_HOST="0.0.0.0"
# ONBOARDING_WS_PORT="3001"
# ONBOARDING_WS_PATH="/api/agent/onboarding/ws"
