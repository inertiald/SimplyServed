# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# LiteLLM proxy URL — used by GeminiBrain and generateAIResponse().
# When running via Docker Compose the default (http://litellm:4000) is correct
# and this variable does not need to be set.
# Override only when running Next.js outside of Docker (e.g. local dev without compose):
# LITELLM_URL=http://localhost:4000
