// SimplyServed schema
// Hyper-local services + community vibe platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 1. DUAL-IDENTITY USER CORE
// -----------------------------------------------------------------------------
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  name            String
  avatarUrl       String?
  role            Role     @default(SUBSCRIBER)

  // JSONB profile blobs — avoids 1:1 explosion while keeping fields searchable.
  consumerProfile Json?    @db.JsonB
  providerProfile Json?    @db.JsonB

  // Internal wallet — Stripe-ready abstraction. Stored in dollars.
  // Two balances so the same account can both spend (consumer) and earn
  // (provider) without re-pricing the UI for the dual-identity model.
  consumerBalance Float @default(0)
  providerBalance Float @default(0)

  listings        Listing[]        @relation("ProviderListings")
  serviceRequests ServiceRequest[] @relation("ConsumerRequests")
  posts           Post[]
  ledgerEntries   LedgerEntry[]
  messages        Message[]
  reviewsAuthored Review[]         @relation("ReviewsAuthored")
  reviewsReceived Review[]         @relation("ReviewsReceived")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

enum Role {
  SUBSCRIBER
  ADMINISTRATOR
}

// -----------------------------------------------------------------------------
// 2. LISTINGS — H3 hex-indexed for hyper-local discovery
// -----------------------------------------------------------------------------
model Listing {
  id          String @id @default(uuid())
  providerId  String
  provider    User   @relation("ProviderListings", fields: [providerId], references: [id], onDelete: Cascade)

  title       String
  description String  @db.Text
  category    String
  hourlyRate  Float

  // Geo + H3 indexing (city = res 7, neighborhood = res 9)
  lat            Float
  lng            Float
  h3City         String
  h3Neighborhood String

  status ListingStatus @default(ACTIVE)

  // Denormalized review aggregates so list/discover queries stay one round-trip.
  // Recomputed inside the same transaction as Review create/update/delete.
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  requests    ServiceRequest[]
  impressions Impression[]
  posts       Post[]
  reviews     Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([h3Neighborhood, status])
  @@index([h3City, status])
  @@index([providerId])
}

enum ListingStatus {
  NEW
  ACTIVE
  INACTIVE
}

// -----------------------------------------------------------------------------
// 3. SERVICE REQUEST — workflow state machine
// -----------------------------------------------------------------------------
model ServiceRequest {
  id         String  @id @default(uuid())
  consumerId String
  consumer   User    @relation("ConsumerRequests", fields: [consumerId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  scheduledDate DateTime?
  status        RequestStatus @default(PLACED)

  feeDetails Json @db.JsonB
  metadata   Json? @db.JsonB

  messages   Message[]
  review     Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consumerId, status])
  @@index([listingId, status])
}

// -----------------------------------------------------------------------------
// 3b. REVIEWS — one per completed request, mutual trust loop
// -----------------------------------------------------------------------------
// We anchor reviews on `ServiceRequest` (1:1) so every review is provably tied
// to a real, completed booking — not a freeform rating-bomb. Aggregates are
// denormalized onto Listing for cheap discover/listing-card rendering.
model Review {
  id         String         @id @default(uuid())
  requestId  String         @unique
  request    ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  authorId   String
  author     User           @relation("ReviewsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  providerId String
  provider   User           @relation("ReviewsReceived", fields: [providerId], references: [id], onDelete: Cascade)

  rating     Int            // 1..5 (validated in the action)
  body       String?        @db.Text

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([listingId, createdAt])
  @@index([providerId, createdAt])
}

// -----------------------------------------------------------------------------
// 3a. MESSAGES — lightweight thread per service request
// -----------------------------------------------------------------------------
// Both the consumer and the provider can post to the thread tied to a request.
// We deliberately don't model arbitrary DMs: every conversation is anchored to
// a real booking so spam and abuse are inherently scoped.
model Message {
  id        String         @id @default(uuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body      String         @db.Text

  createdAt DateTime       @default(now())

  @@index([requestId, createdAt])
}

enum RequestStatus {
  PLACED
  RESPONDED
  SCHEDULED
  CONFIRMED
  COMMENCED
  STARTED
  DELIVERED
  COMPLETED
  DROPPED
  CANCELED
}

// -----------------------------------------------------------------------------
// 4. IMPRESSIONS — neighborhood vibe reactions
// -----------------------------------------------------------------------------
model Impression {
  id        String  @id @default(uuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // HMAC of (user|listing|hour-bucket) — dedupes spam without storing user link.
  impressionHash String   @unique
  reactionType   Reaction

  createdAt DateTime @default(now())

  @@index([listingId, reactionType])
}

enum Reaction {
  LIKE
  LOVE
  WOW
}

// -----------------------------------------------------------------------------
// 5. POSTS — polymorphic neighborhood vibe / business / offers
// -----------------------------------------------------------------------------
model Post {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  postType    PostType  @default(GENERAL)
  contentText String    @db.Text
  mediaType   MediaType @default(TEXT_ONLY)
  mediaUrls   Json?     @db.JsonB

  lat            Float
  lng            Float
  h3Neighborhood String

  // Polymorphic extension — e.g. { offer: { code, expires, discount } }
  metadata Json? @db.JsonB

  status PostStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([h3Neighborhood, status, createdAt(sort: Desc)])
  @@index([listingId])
  @@index([userId])
}

enum PostType {
  GENERAL
  BUSINESS
  OFFER
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT_ONLY
}

enum PostStatus {
  ACTIVE
  EXPIRED
  DELETED
  REPORTED
}

// -----------------------------------------------------------------------------
// 6. WALLET LEDGER — append-only money movements (Stripe-ready)
// -----------------------------------------------------------------------------
// Every balance change is mirrored as a row here so we have a full audit trail
// and can rebuild balances if needed. `(requestId, kind)` is unique so that
// payment side-effects in the request workflow are perfectly idempotent — a
// double-click on "Confirm" or "Complete" can't double-charge.
model LedgerEntry {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestId String?
  kind      LedgerKind
  amount    Float   // signed: negative = debit, positive = credit
  currency  String  @default("USD")
  memo      String?

  createdAt DateTime @default(now())

  @@unique([requestId, kind])
  @@index([userId, createdAt(sort: Desc)])
}

enum LedgerKind {
  TOPUP        // consumer adds funds to wallet (demo "Add $X")
  HOLD         // consumer → escrow when request is CONFIRMED
  RELEASE      // escrow → provider when request is COMPLETED
  FEE          // platform fee taken from the release
  REFUND       // escrow → consumer when request is CANCELED/DROPPED after hold
  ADJUSTMENT   // manual adjustment (admin)
}
