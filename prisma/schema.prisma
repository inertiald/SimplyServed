// SimplyServed schema
// Hyper-local services + community vibe platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// 1. DUAL-IDENTITY USER CORE
// -----------------------------------------------------------------------------
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  name            String
  avatarUrl       String?
  role            Role     @default(SUBSCRIBER)
  stripeConnectAccountId      String?  @unique
  stripeConnectOnboarded      Boolean  @default(false)
  stripeConnectPayoutsEnabled Boolean  @default(false)

  // JSONB profile blobs — avoids 1:1 explosion while keeping fields searchable.
  consumerProfile Json?    @db.JsonB
  providerProfile Json?    @db.JsonB

  // Internal wallet — Stripe-ready abstraction. Stored in dollars.
  // Two balances so the same account can both spend (consumer) and earn
  // (provider) without re-pricing the UI for the dual-identity model.
  consumerBalance Float @default(0)
  providerBalance Float @default(0)

  listings        Listing[]        @relation("ProviderListings")
  serviceRequests ServiceRequest[] @relation("ConsumerRequests")
  posts           Post[]
  ledgerEntries   LedgerEntry[]
  messages        Message[]
  reviewsAuthored Review[]         @relation("ReviewsAuthored")
  reviewsReceived Review[]         @relation("ReviewsReceived")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

enum Role {
  SUBSCRIBER
  ADMINISTRATOR
}

// -----------------------------------------------------------------------------
// 2. LISTINGS — H3 hex-indexed for hyper-local discovery
// -----------------------------------------------------------------------------
model Listing {
  id          String @id @default(uuid())
  providerId  String
  provider    User   @relation("ProviderListings", fields: [providerId], references: [id], onDelete: Cascade)

  title       String
  description String  @db.Text
  category    String
  hourlyRate  Float

  // Geo + H3 indexing (city = res 7, neighborhood = res 9)
  lat            Float
  lng            Float
  h3City         String
  h3Neighborhood String

  status ListingStatus @default(ACTIVE)

  // Denormalized review aggregates so list/discover queries stay one round-trip.
  // Recomputed inside the same transaction as Review create/update/delete.
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  // When a scraped BusinessProfile is claimed and converted into a Listing,
  // we keep a back-pointer here so refreshes can update non-overridden fields.
  // `ownerOverrides` is a JSON mask of field names the owner has manually
  // edited (e.g. { "description": true }) — those fields are never overwritten
  // by future scrape refreshes.
  originBusinessProfileId String?          @unique
  originBusinessProfile   BusinessProfile? @relation("BusinessProfileClaim", fields: [originBusinessProfileId], references: [id], onDelete: SetNull)
  ownerOverrides          Json?            @db.JsonB

  requests    ServiceRequest[]
  impressions Impression[]
  posts       Post[]
  reviews     Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([h3Neighborhood, status])
  @@index([h3City, status])
  @@index([providerId])
}

enum ListingStatus {
  NEW
  ACTIVE
  INACTIVE
}

// -----------------------------------------------------------------------------
// 3. SERVICE REQUEST — workflow state machine
// -----------------------------------------------------------------------------
model ServiceRequest {
  id         String  @id @default(uuid())
  consumerId String
  consumer   User    @relation("ConsumerRequests", fields: [consumerId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  scheduledDate DateTime?
  status        RequestStatus @default(PLACED)

  feeDetails Json @db.JsonB
  metadata   Json? @db.JsonB

  messages   Message[]
  review     Review?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([consumerId, status])
  @@index([listingId, status])
}

// -----------------------------------------------------------------------------
// 3b. REVIEWS — one per completed request, mutual trust loop
// -----------------------------------------------------------------------------
// We anchor reviews on `ServiceRequest` (1:1) so every review is provably tied
// to a real, completed booking — not a freeform rating-bomb. Aggregates are
// denormalized onto Listing for cheap discover/listing-card rendering.
model Review {
  id         String         @id @default(uuid())
  requestId  String         @unique
  request    ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  listingId  String
  listing    Listing        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  authorId   String
  author     User           @relation("ReviewsAuthored", fields: [authorId], references: [id], onDelete: Cascade)
  providerId String
  provider   User           @relation("ReviewsReceived", fields: [providerId], references: [id], onDelete: Cascade)

  rating     Int            // 1..5 (validated in the action)
  body       String?        @db.Text

  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([listingId, createdAt])
  @@index([providerId, createdAt])
}

// -----------------------------------------------------------------------------
// 3a. MESSAGES — lightweight thread per service request
// -----------------------------------------------------------------------------
// Both the consumer and the provider can post to the thread tied to a request.
// We deliberately don't model arbitrary DMs: every conversation is anchored to
// a real booking so spam and abuse are inherently scoped.
model Message {
  id        String         @id @default(uuid())
  requestId String
  request   ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorId  String
  author    User           @relation(fields: [authorId], references: [id], onDelete: Cascade)

  body      String         @db.Text

  createdAt DateTime       @default(now())

  @@index([requestId, createdAt])
}

enum RequestStatus {
  PLACED
  RESPONDED
  SCHEDULED
  CONFIRMED
  COMMENCED
  STARTED
  DELIVERED
  COMPLETED
  DROPPED
  CANCELED
}

// -----------------------------------------------------------------------------
// 4. IMPRESSIONS — neighborhood vibe reactions
// -----------------------------------------------------------------------------
model Impression {
  id        String  @id @default(uuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // HMAC of (user|listing|hour-bucket) — dedupes spam without storing user link.
  impressionHash String   @unique
  reactionType   Reaction

  createdAt DateTime @default(now())

  @@index([listingId, reactionType])
}

enum Reaction {
  LIKE
  LOVE
  WOW
}

// -----------------------------------------------------------------------------
// 5. POSTS — polymorphic neighborhood vibe / business / offers
// -----------------------------------------------------------------------------
model Post {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  postType    PostType  @default(GENERAL)
  contentText String    @db.Text
  mediaType   MediaType @default(TEXT_ONLY)
  mediaUrls   Json?     @db.JsonB

  lat            Float
  lng            Float
  h3Neighborhood String

  // Polymorphic extension — e.g. { offer: { code, expires, discount } }
  metadata Json? @db.JsonB

  status PostStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([h3Neighborhood, status, createdAt(sort: Desc)])
  @@index([listingId])
  @@index([userId])
}

enum PostType {
  GENERAL
  BUSINESS
  OFFER
}

enum MediaType {
  IMAGE
  VIDEO
  TEXT_ONLY
}

enum PostStatus {
  ACTIVE
  EXPIRED
  DELETED
  REPORTED
}

// -----------------------------------------------------------------------------
// 6. WALLET LEDGER — append-only money movements (Stripe-ready)
// -----------------------------------------------------------------------------
// Every balance change is mirrored as a row here so we have a full audit trail
// and can rebuild balances if needed. `(requestId, kind)` is unique so that
// payment side-effects in the request workflow are perfectly idempotent — a
// double-click on "Confirm" or "Complete" can't double-charge.
model LedgerEntry {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  requestId String?
  kind      LedgerKind
  amount    Float   // signed: negative = debit, positive = credit
  currency  String  @default("USD")
  memo      String?
  stripePaymentIntentId String? @unique
  stripeTransferId      String? @unique
  stripeRefundId        String? @unique
  stripePayoutId        String? @unique
  stripeStatus          String?

  createdAt DateTime @default(now())

  @@unique([requestId, kind])
  @@index([userId, createdAt(sort: Desc)])
}

model StripeWebhookEvent {
  id         String   @id @default(uuid())
  eventId    String   @unique
  type       String
  processedAt DateTime?
  createdAt  DateTime @default(now())
}

enum LedgerKind {
  TOPUP        // consumer adds funds to wallet (demo "Add $X")
  HOLD         // consumer → escrow when request is CONFIRMED
  RELEASE      // escrow → provider when request is COMPLETED
  FEE          // platform fee taken from the release
  REFUND       // escrow → consumer when request is CANCELED/DROPPED after hold
  ADJUSTMENT   // manual adjustment (admin)
}

// -----------------------------------------------------------------------------
// 7. BUSINESS PROFILES — OSINT-scraped, dedup'd, mergeable, claimable
// -----------------------------------------------------------------------------
// `BusinessProfile` is the canonical row for a business that was discovered
// out in the wild (OSM, Yelp, Google, chamber-of-commerce directories, …).
// Multiple `BusinessSource` rows attach raw payloads from each provider for
// audit + re-merge. When a real owner completes the claim flow we mint a
// `Listing` from this profile and back-link via `Listing.originBusinessProfileId`.
model BusinessProfile {
  id   String @id @default(uuid())
  slug String @unique

  name        String
  description String? @db.Text
  category    String?
  phone       String?
  email       String?
  website     String?

  address    String?
  city       String?
  region     String?
  postalCode String?
  country    String?

  // Geo + H3 indexing (same convention as Listing for cheap cross-queries).
  lat            Float?
  lng            Float?
  h3City         String?
  h3Neighborhood String?

  hours       Json?    @db.JsonB
  socialLinks Json?    @db.JsonB
  tags        String[] @default([])

  // Cross-source aggregated rating snapshot. Per-source ratings live on
  // `BusinessSource.rating` / `reviewCount` for attribution.
  ratingAvg   Float @default(0)
  ratingCount Int   @default(0)

  // Dedup: SHA-256 of (normalizedName | normalizedPhone | geoBucket).
  // Unique so a second source for the same business attaches instead of
  // duplicating.
  dedupeKey       String @unique
  confidenceScore Float  @default(1)

  claimStatus      ClaimStatus @default(UNCLAIMED)
  claimedListingId String?     @unique
  claimedListing   Listing?    @relation("BusinessProfileClaim")

  // When set, this profile has been taken down (owner request, copyright,
  // ToS violation, etc.) and must not be re-ingested by scrape runs.
  tombstonedAt     DateTime?
  tombstoneReason  String?

  lastScrapedAt DateTime?
  nextScrapeAt  DateTime?

  sources     BusinessSource[]
  media       BusinessMedia[]
  claims      BusinessClaim[]
  priceQuotes BusinessPriceQuote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([h3Neighborhood, claimStatus])
  @@index([h3City, claimStatus])
  @@index([nextScrapeAt])
  @@index([claimStatus, createdAt])
}

enum ClaimStatus {
  UNCLAIMED
  PENDING
  CLAIMED
  REJECTED
}

model BusinessSource {
  id                String          @id @default(uuid())
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  source      ScrapeSource
  sourceUrl   String
  externalId  String?
  rawPayload  Json         @db.JsonB
  rating      Float?
  reviewCount Int?

  fetchedAt   DateTime @default(now())
  etag        String?
  contentHash String?

  @@unique([source, sourceUrl])
  @@unique([source, externalId])
  @@index([businessProfileId])
}

enum ScrapeSource {
  YELP
  GOOGLE
  BBB
  YELLOWPAGES
  CHAMBER
  OPENSTREETMAP
  FACEBOOK
  INSTAGRAM
  DOORDASH
  UBEREATS
  GRUBHUB
  ANGI
  THUMBTACK
  WEBSITE
  OTHER
}

model BusinessMedia {
  id                String          @id @default(uuid())
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  kind         MediaKind
  url          String // stored copy (lib/storage.ts)
  originUrl    String
  originSource ScrapeSource
  width        Int?
  height       Int?
  phash        String? // perceptual hash for image dedup
  caption      String?

  createdAt DateTime @default(now())

  @@unique([businessProfileId, phash])
  @@index([businessProfileId, kind])
}

enum MediaKind {
  IMAGE
  VIDEO
}

// -----------------------------------------------------------------------------
// 7b. PRICE QUOTES — cross-channel price comparison
// -----------------------------------------------------------------------------
// A single advertised price for a business on a specific sales channel
// (the company's own website, DoorDash, Angi, …). Many quotes per profile
// power the price-comparison table. `url` is the public storefront/listing
// URL for that channel; the app turns it into a native deep link at render
// time (`lib/deeplinks.ts`) so a consumer can purchase via that method.
//
// Quotes are upserted per `(businessProfileId, channel, label)` so a re-scrape
// of the same channel updates the price in place instead of duplicating it.
model BusinessPriceQuote {
  id                String          @id @default(uuid())
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  channel PriceChannel
  source  ScrapeSource

  // Human-readable item/service this price is for (e.g. "Margherita Pizza",
  // "Drain unclogging", "Standard session"). Defaults to a channel label when
  // the source only advertises a single headline price.
  label String

  amount   Float // in `currency` major units (e.g. dollars)
  currency String  @default("USD")
  unit     String? // e.g. "each", "per hour", "delivery", "+ fees"

  // Public storefront/listing URL on this channel. Used to build the native
  // deep link + web fallback the consumer taps to buy.
  url       String?
  available Boolean @default(true)

  // Stable per-channel id (e.g. DoorDash store id) when known — lets a refresh
  // line up with the prior quote even if the label changes.
  externalId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessProfileId, channel, label])
  @@index([businessProfileId, amount])
}

enum PriceChannel {
  DIRECT // the business's own website / storefront
  DOORDASH
  UBEREATS
  GRUBHUB
  ANGI // formerly Angie's List
  THUMBTACK
  OTHER
}

model BusinessClaim {
  id                String          @id @default(uuid())
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  claimantUserId String
  status         ClaimDecisionStatus @default(PENDING)

  verificationMethod  VerificationMethod
  verificationPayload Json?              @db.JsonB

  submittedAt    DateTime  @default(now())
  decidedAt      DateTime?
  decidedByUserId String?

  @@index([businessProfileId, status])
  @@index([claimantUserId, status])
}

enum ClaimDecisionStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum VerificationMethod {
  EMAIL_DOMAIN
  PHONE_OTP
  DOC_UPLOAD
  ADMIN
}

model ScrapeJob {
  id     String       @id @default(uuid())
  source ScrapeSource
  target String // e.g. city slug, h3 cell, category, or chamber site id

  status        ScrapeJobStatus @default(QUEUED)
  startedAt     DateTime?
  finishedAt    DateTime?
  itemsSeen     Int             @default(0)
  itemsUpserted Int             @default(0)
  itemsRejected Int             @default(0)
  error         String?
  cursor        Json?           @db.JsonB

  createdAt DateTime @default(now())

  @@index([source, status, createdAt])
  @@index([status, createdAt])
}

enum ScrapeJobStatus {
  QUEUED
  RUNNING
  OK
  FAILED
  RATE_LIMITED
}
